# 应用配置
APP_NAME=WriteGeniusAI
APP_VERSION=1.0.0
DEBUG=True

# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# API 配置
API_TIMEOUT=30
API_RETRY_COUNT=3

# 模型配置
DEFAULT_MODEL=gpt-3.5-turbo
MAX_TOKENS=1000
TEMPERATURE=0.7

# 模型提供者配置 (openai, ollama)
MODEL_PROVIDER=openai